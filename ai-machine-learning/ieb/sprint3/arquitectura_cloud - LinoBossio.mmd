    classDef sec fill:#C44E52,stroke:#243A5E,color:#ffffff,stroke-width:1px;
    classDef gov fill:#243A5E,stroke:#243A5E,color:#ffffff,stroke-width:1px;
    classDef aux fill:#E8ECF1,stroke:#5A6B7B,color:#243A5E,stroke-width:1px;

